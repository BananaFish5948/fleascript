# ========================================
# FleaScript 環境変数テンプレート
# ========================================
# 【ローカル開発の場合】
# このファイルをコピーして `.env.local` を作成し、実際の値を入力してください。
#
# 【Vercelデプロイ（本番環境）の場合】
# Vercelのダッシュボード > Settings > Environment Variables に以下のキーと値をすべて登録してください。
# ========================================

# --- OpenAI ---
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Supabase (本番環境のProject Settings > APIから取得) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- アプリ設定 ---
# レートリミット: 1日あたりの最大生成回数（デフォルト: 3）
RATE_LIMIT_PER_DAY=3

# --- 管理ダッシュボード ---
# /admin へのアクセス用Basic認証情報（類推されにくいものに変更推奨）
ADMIN_USER=admin
ADMIN_PASS=password

# --- アプリURL ---
# バイラルクレジットやOGP用URL。本番ドメインが決まったら設定します。
# 例: https://fleascript.vercel.app または https://www.fleascript.com
NEXT_PUBLIC_APP_URL=https://fleascript.vercel.app
